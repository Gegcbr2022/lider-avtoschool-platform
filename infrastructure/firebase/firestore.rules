rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasRole(role) {
      return signedIn() && request.auth.token.role == role;
    }

    function staff() {
      return hasRole("admin") || hasRole("manager");
    }

    function ownsResource() {
      return signedIn() && resource.data.studentId == request.auth.uid;
    }

    function createsOwnResource() {
      return signedIn() && request.resource.data.studentId == request.auth.uid;
    }

    function keepsOwnResource() {
      return ownsResource() && request.resource.data.studentId == request.auth.uid;
    }

    function validPublicLeadCreate() {
      return request.resource.data.keys().hasAll(["name", "phone", "city", "category", "source", "status", "consentAccepted", "createdAt"])
        && request.resource.data.consentAccepted == true
        && request.resource.data.status == "new"
        && request.resource.data.name is string
        && request.resource.data.phone is string
        && request.resource.data.city is string;
    }

    match /leads/{leadId} {
      allow create: if validPublicLeadCreate();
      allow read, update, delete: if staff();
    }

    match /students/{studentId} {
      allow read, update: if staff() || (signedIn() && request.auth.uid == studentId);
      allow create, delete: if staff();
    }

    match /bookings/{bookingId} {
      allow read: if staff() || ownsResource();
      allow update: if staff() || keepsOwnResource();
      allow create: if staff() || createsOwnResource();
      allow delete: if staff();
    }

    match /payments/{paymentId} {
      allow read: if staff() || ownsResource();
      allow write: if staff();
    }

    match /courses/{courseId} {
      allow read: if signedIn();
      allow write: if staff();
    }

    match /auditLogs/{logId} {
      allow read: if hasRole("admin");
      allow write: if false;
    }

    match /kpiSnapshots/{snapshotId} {
      allow read: if staff();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
