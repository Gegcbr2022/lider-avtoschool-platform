rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function staff() {
      return signedIn() && (request.auth.token.role == "admin" || request.auth.token.role == "manager");
    }

    function isImageOrPdf() {
      return request.resource.contentType.matches("application/pdf|image/.*");
    }

    function isChatAttachment() {
      return request.resource.contentType.matches(
        "image/.*|application/pdf|text/.*|application/octet-stream|application/msword|application/vnd.ms-excel|application/vnd.ms-powerpoint|application/vnd.openxmlformats-officedocument.*|application/zip"
      );
    }

    function underSizeLimit() {
      return request.resource.size < 10 * 1024 * 1024;
    }

    // Документы, загруженные учеником в своём кабинете
    match /student-documents/{studentId}/{fileName} {
      allow read: if staff() || (signedIn() && request.auth.uid == studentId);
      allow write: if (staff() || (signedIn() && request.auth.uid == studentId))
        && underSizeLimit()
        && isImageOrPdf();
    }

    match /users/{userId}/documents/{fileName} {
      allow read: if staff() || (signedIn() && request.auth.uid == userId);
      allow write: if (staff() || (signedIn() && request.auth.uid == userId))
        && underSizeLimit()
        && isImageOrPdf();
    }

    match /avatars/{userId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn()
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches("image/.*");
    }

    // Документы, приложенные к публичным заявкам (анонимный upload)
    // Путь содержит leadId, сгенерированный на бэкенде, — случайный UUID, не угадываемый
    match /lead-documents/{leadId}/{fileName} {
      allow create: if underSizeLimit() && isImageOrPdf();
      allow read, update, delete: if staff();
    }

    // Публичные ассеты (логотипы, фото для CMS)
    match /public/{fileName} {
      allow read: if true;
      allow write: if staff();
    }

    // Фото и медиа в чатах — участники чата + стафф
    // uploadChatImage() пишет сюда: conversations/{convId}/attachments/{name}
    match /conversations/{conversationId}/attachments/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn()
        && request.resource.size < 10 * 1024 * 1024
        && isChatAttachment();
    }

    // Stories media (для будущих image-stories)
    match /stories/{storyId}/{fileName} {
      allow read: if true;
      allow write: if signedIn()
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches("image/.*|video/mp4");
    }

    // Club post media
    match /clubMedia/{postId}/{fileName} {
      allow read: if true;
      allow write: if signedIn()
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches("image/.*");
    }

    // Legacy sprint-24 path kept so old already-uploaded drafts do not break.
    match /clubMedia/{fileName} {
      allow read: if true;
      allow write: if signedIn()
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches("image/.*");
    }

    // Запрещаем всё остальное
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
