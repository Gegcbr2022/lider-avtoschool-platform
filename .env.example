NEXT_PUBLIC_SITE_URL=http://localhost:3000
APP_DOMAIN=localhost
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
API_URL=http://localhost:5001/lider-avtoschool-dev/europe-west1/api
FIREBASE_PROJECT_ID=lider-avtoschool-dev
FIREBASE_STORAGE_BUCKET=lider-avtoschool-dev.firebasestorage.app

# Firebase public config (safe to expose — access controlled by Security Rules)
# Get from Firebase Console → Project Settings → Your apps → Web app → firebaseConfig
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=lider-avtoschool-dev
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=lider-avtoschool-dev.firebasestorage.app
NEXT_PUBLIC_FIREBASE_APP_ID=
SENTRY_DSN=
POSTHOG_KEY=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
# Smart CAPTCHA / Cloudflare Turnstile.
# Normal low-risk lead submissions do not show CAPTCHA.
# High-risk submissions require Turnstile and are verified by the API.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_LOG_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_DEFAULT_START_PARAM=AYYUTE
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Email notifications for new leads
# Set LEAD_EMAIL_ENABLED=true, LEAD_EMAIL_TO, LEAD_EMAIL_FROM and one transport to activate.
# API auto-selects Resend when RESEND_API_KEY exists, otherwise SMTP_*.
# Lead records persist emailNotificationStatus/reason/messageId for diagnostics.
LEAD_EMAIL_ENABLED=false
LEAD_EMAIL_TO=
LEAD_EMAIL_CC=
LEAD_EMAIL_FROM=
LEAD_EMAIL_PROVIDER=resend
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Per-branch email recipients (optional, falls back to LEAD_EMAIL_TO)
LEAD_EMAIL_TO_KYIV=
LEAD_EMAIL_TO_SLOVIANSK=
LEAD_EMAIL_TO_KRAMATORSK=
LEAD_EMAIL_TO_DNIPRO=
LEAD_EMAIL_TO_DOBROPILLIA=

LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=
FONDY_MERCHANT_ID=
FONDY_SECRET_KEY=
MONOBANK_TOKEN=
