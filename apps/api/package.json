{
  "name": "@lider/api",
  "version": "0.1.0",
  "private": true,
  "main": "lib/index.js",
  "scripts": {
    "dev": "firebase emulators:start --only functions,firestore,storage",
    "build": "tsup src/index.ts --format cjs --target node20 --out-dir lib --clean",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "deploy": "firebase deploy --only functions"
  },
  "dependencies": {
    "@lider/shared": "file:../../packages/shared",
    "@lider/types": "file:../../packages/types",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "firebase-admin": "^13.3.0",
    "firebase-functions": "^6.3.2",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "firebase-tools": "^15.19.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20 <23"
  }
}
